DATABASE_URL=file:/home/z/my-project/db/custom.db

# MSG91 SMS OTP (customer, seller, delivery-boy login)
# NOTE: MSG91_SENDER_ID must be EXACTLY 6 alphabetic chars (DLT/TRAI rule).
#       "Realcart" (8 chars) is INVALID and SMS will not be delivered.
#       Register a 6-char sender ID on your DLT portal (e.g. REALCT) and
#       update MSG91_SENDER_ID below to match the approved sender ID.
MSG91_AUTH_KEY=548435A9y8h3RKYX6a4ddac0P1
MSG91_SENDER_ID=REALCT
MSG91_TEMPLATE_ID=6a4de9f99c9dbda5fe0da9a3
MSG91_ROUTE=4

# SMSHorizon (PRIMARY OTP provider — smshorizon.co.in)
# Free account: 500 free SMS credits, no card required.
# Sign up at https://smshorizon.co.in → dashboard → copy API key + username.
# Register a 6-char DLT sender ID + approved template, then set below.
# If SMSHorizon is not configured, the app falls back to MSG91, then dev mode.
SMSHORIZON_API_KEY=your-smshorizon-api-key
SMSHORIZON_USER=your-smshorizon-username
SMSHORIZON_SENDER_ID=REALCT
SMSHORIZON_TEMPLATE_ID=your-smshorizon-dlt-template-id
SMSHORIZON_TYPE=txt
