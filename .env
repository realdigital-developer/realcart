DATABASE_URL=file:/home/z/my-project/db/custom.db

# SMS OTP delivery mode (RCS vs DLT)
# false (default) = RCS / non-DLT mode — sends OTP WITHOUT a DLT template ID.
#                   The message is delivered via RCS / non-DLT channel.
# true            = DLT mode — sends the DLT template ID with each request
#                   (requires MSG91_TEMPLATE_ID / SMSHORIZON_TEMPLATE_ID).
SMS_USE_DLT=false

# MSG91 (FALLBACK OTP provider — msg91.com)
# Sender ID must be 6 alphabetic chars. Template ID only used if SMS_USE_DLT=true.
MSG91_AUTH_KEY=548435A9y8h3RKYX6a4ddac0P1
MSG91_SENDER_ID=REALCT
MSG91_TEMPLATE_ID=6a4de9f99c9dbda5fe0da9a3
MSG91_ROUTE=4

# SMSHorizon (PRIMARY OTP provider — smshorizon.co.in)
# Free account: 500 free SMS credits, no card required.
# Sender ID must be 6 alphabetic chars. Template ID only used if SMS_USE_DLT=true.
# If SMSHorizon is not configured, the app falls back to MSG91, then dev mode.
SMSHORIZON_API_KEY=0ab58aec6688d9127db1
SMSHORIZON_USER=realcart
SMSHORIZON_SENDER_ID=SMSHZN
SMSHORIZON_TEMPLATE_ID=1507160907763157612
SMSHORIZON_TYPE=txt
