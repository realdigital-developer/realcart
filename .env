DATABASE_URL=file:/home/z/my-project/db/custom.db

# SMS OTP delivery mode: RCS (no sender ID, no DLT)
# false (default) = RCS mode — sends OTP WITHOUT sender ID and WITHOUT DLT template ID.
#                   MSG91 uses its default global sender — no registration needed.
# true            = DLT mode — requires sender ID + DLT template ID.
SMS_USE_DLT=false

# MSG91 (OTP provider — msg91.com)
# RCS mode: NO sender ID needed. MSG91 uses its default global sender.
# Only MSG91_AUTH_KEY is required. Sender ID + template ID are optional (DLT mode only).
MSG91_AUTH_KEY=548435A9y8h3RKYX6a4ddac0P1
# MSG91_SENDER_ID=REALCT       # Optional — only for DLT mode. Omit for RCS mode.
# MSG91_TEMPLATE_ID=...        # Optional — only for DLT mode. Omit for RCS mode.
MSG91_ROUTE=4

# SMSHorizon (PRIMARY OTP provider — smshorizon.co.in)
# NOTE: SMSHorizon's API REQUIRES a sender ID. For RCS mode without sender ID,
# SMSHORIZON_SENDER_ID is commented out → SMSHorizon is skipped → MSG91 is used.
# To use SMSHorizon, uncomment SMSHORIZON_SENDER_ID and set a registered 6-char value.
SMSHORIZON_API_KEY=0ab58aec6688d9127db1
SMSHORIZON_USER=realcart
# SMSHORIZON_SENDER_ID=SMSHZN  # Required by SMSHorizon API. Omit to skip SMSHorizon.
# SMSHORIZON_TEMPLATE_ID=...   # Optional — only for DLT mode.
SMSHORIZON_TYPE=txt
