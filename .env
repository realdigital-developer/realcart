DATABASE_URL=file:/home/z/my-project/db/custom.db

# SIM Binding (banking-app style login — user sends SMS from their phone)
# The user enters their phone number, the app generates a secret code, and the
# user sends an SMS from their phone to the server number with the code.
# The inbound SMS webhook verifies the sender + code and binds the SIM.
#
# Dev mode (default): auto-verifies after 3 seconds (no SMS gateway needed).
# Production: set SIM_BINDING_SERVER_NUMBER to your inbound SMS number, and
#   configure your SMS gateway to forward received SMS to /api/sms/inbound.
SIM_BINDING_DEV_MODE=true
SIM_BINDING_SERVER_NUMBER=
INBOUND_SMS_WEBHOOK_SECRET=
