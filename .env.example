# ────────────────────────────────────────────────────────────────────
# RealCart — Environment Variables Reference
# ────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (local dev) or set these keys in your
# deployment dashboard (Vercel → Project → Settings → Environment Variables).
#
# Most variables have safe fallbacks in the source code, so the app
# will boot without them. The ones marked [REQUIRED] should be set
# for a real production deployment.

# ─── Core ──────────────────────────────────────────────────────────
NODE_ENV=production

# Public base URL of your deployment. Used for payment redirects,
# email links, OAuth callback URLs, etc.
# Example (Vercel):  https://realcart.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# NextAuth / JWT signing secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=https://your-app.vercel.app

# MongoDB Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/realcart

# ─── Cloudinary (image uploads — REQUIRED for product/review images) ─
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Razorpay (payments — REQUIRED for checkout) ───────────────────
RAZORPAY_KEY_ID=rzp_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# ─── SMTP (transactional email — REQUIRED for order emails) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
SMTP_FROM="RealCart <noreply@yourdomain.com>"

# ─── SMSHorizon (PRIMARY SMS OTP provider — smshorizon.co.in) ─────────
# Used for mobile OTP login/registration across all three panels.
# SMSHorizon is tried FIRST. If not configured or if it fails, the app falls
# back to MSG91 (below), then to dev mode (test OTP 123456).
#
# Get these from: https://smshorizon.co.in
#   1. Sign up for a free account → 500 free SMS credits, no card required.
#   2. API_KEY + USER: Dashboard → API section → copy your API key + username.
#   3. SENDER_ID: MUST be EXACTLY 6 alphabetic characters (DLT/TRAI rule).
#      Register + approve it on your DLT portal (SMSHorizon assists, ~24-48h).
#   4. TEMPLATE_ID (DLT): register an SMS template whose content EXACTLY matches
#      the message built by buildOtpMessage() in src/lib/sms-otp.ts. Copy the
#      template ID (tid). Required for Indian DLT/TRAI compliance.
#   5. TYPE: "txt" (default, English) or "uni" (Unicode/regional languages).
#
# API details: POST https://smshorizon.co.in/api/v2/sendsms.php
#   Auth: Authorization: Bearer <SMSHORIZON_API_KEY>
#   Body (form-encoded): user, mobile, senderid, message, tid, type
#   Success response: {"msgid":"...","status":"queued","balance_after":"499"}
#
# The app generates and verifies the OTP server-side (SHA-256 hash in the
# otp_sessions MongoDB collection) — SMSHorizon only delivers the SMS.
#
# Vercel deployment: add all SMSHORIZON_* vars in Project Settings →
# Environment Variables.
SMSHORIZON_API_KEY=your-smshorizon-api-key
SMSHORIZON_USER=your-smshorizon-username
SMSHORIZON_SENDER_ID=REALCT
SMSHORIZON_TEMPLATE_ID=your-smshorizon-dlt-template-id
SMSHORIZON_TYPE=txt

# ─── MSG91 (FALLBACK SMS OTP provider — msg91.com) ───────────────────
# Used as fallback when SMSHorizon is not configured or fails.
# Kept fully intact — do not remove if you want fallback redundancy.
#
# Get these from: https://msg91.com
#   1. Sign up for an account (free trial includes some SMS credits).
#   2. AUTH_KEY: Dashboard → top-right → API → copy the Auth Key
#   3. SENDER_ID: MUST be EXACTLY 6 alphabetic characters (DLT/TRAI rule).
#   4. TEMPLATE_ID (DLT): register an SMS template matching buildOtpMessage().
#   5. ROUTE: "4" = transactional (default, correct for OTP).
#
# Vercel: add all four MSG91_* vars in Project Settings → Environment Variables.
# Vercel's egress IPs are dynamic — if you enable MSG91 API Security (IP
# whitelist), whitelist ALL Vercel egress IPs or disable it.
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=REALCT
MSG91_TEMPLATE_ID=your-dlt-template-id
MSG91_ROUTE=4

# ─── Google Drive (optional backup storage) ────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/admin/drive/callback
GOOGLE_DRIVE_FOLDER_ID=root

# ─── Image Search — Free-tier API keys (all optional but recommended) ─
# These enable production-quality visual search (like Meesho).
# Get them FREE — the system works without them (fallback mode) but
# results are MUCH more accurate with them configured.

# Groq (FREE — https://console.groq.com/docs/api-keys)
# Enables AI vision analysis: extracts category, gender, color, style, etc.
GROQ_API_KEY=your_groq_api_key_here

# Jina AI (FREE — https://jina.ai/api-key/)
# Enables real image embeddings (CLIP v2) for semantic visual similarity.
JINA_API_KEY=your_jina_api_key_here

# Pinecone (FREE — https://www.pinecone.io/pricing/)
# Cloud vector database for fast nearest-neighbor search at scale.
# Without this, a local FAISS-compatible flat index is used.
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=realcart-image-search

# Algolia (FREE — https://www.algolia.com/pricing)
# Fast metadata filtering by category/gender/color.
# Without this, MongoDB queries are used as a fallback.
ALGOLIA_APP_ID=your_algolia_app_id_here
ALGOLIA_API_KEY=your_algolia_api_key_here
ALGOLIA_INDEX_NAME=realcart_products

# Ximilar (OPTIONAL — https://app.ximilar.com/)
# Fashion-specific attribute extraction. Groq provides these too.
XIMILAR_API_KEY=your_ximilar_api_key_here
